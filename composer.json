{
  "name": "sunflower/dental-lab",
  "description": "Open-source dental lab order & invoice manager (PHP + MySQL).",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*"
  },
  "autoload": {
    "psr-4": {
      "Sunflower\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
