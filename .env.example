# =====================================================
# Sunflower Dental Lab — environment configuration
# Copy this file to `.env` for local development.
# In production (DO App Platform) set these via the
# dashboard → Settings → App-Level Environment Variables.
# =====================================================

# Database (Managed MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sunflower
DB_USER=sunflower
DB_PASS=changeme
DB_SSL=0                     # set 1 in production (DO Managed MySQL requires TLS)

# App
APP_ENV=development          # development | production
APP_DEBUG=1                  # 1 = show errors; MUST be 0 in production
APP_URL=http://localhost:8000
APP_TZ=Asia/Kuala_Lumpur

# Session / security
SESSION_NAME=sfdl_sess
SESSION_LIFETIME=43200       # seconds (12h)
COOKIE_SECURE=0              # 1 in production (HTTPS)

# Business defaults (used on invoices/receipts)
BUSINESS_NAME="Sunflower Malaysia Dental Lab"
BUSINESS_PHONE="011-56739132"
BUSINESS_ADDRESS=""
INVOICE_PREFIX="SF"
INVOICE_START=576
